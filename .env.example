# Broker and execution settings
# Keep AUTO_SUBMIT=false until you have manually reviewed the queue and set approval_status to approved.
BROKER_NAME=alpaca
TRADING_MODE=paper
AUTO_SUBMIT=false
USE_PROXY_EQUITIES=true
PAPER_ACCOUNT_SIZE=100000
MAX_OPEN_POSITIONS=5
MAX_POSITION_PCT=2.0

# Alpaca credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Safety switch for any future live routing
CONFIRM_LIVE_TRADING=false

# Exit automation stays disabled until you have reviewed exit_recommendations.csv
ENABLE_EXIT_AUTOMATION=false
